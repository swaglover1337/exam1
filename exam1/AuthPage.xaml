<Page x:Class="exam1.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:exam1"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Grid Background="#F5F5F5">
        <StackPanel Width="250" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Авторизация" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,20" FontWeight="Bold"/>

            <TextBlock Text="Логин:" Margin="0,5,0,2"/>
            <TextBox Name="LoginTextBox" Padding="5"/>

            <TextBlock Text="Пароль:" Margin="0,10,0,2"/>
            <PasswordBox Name="PasswordTextBox" Padding="5"/>

            <Button Content="Войти" Click="LoginButton_Click" Margin="10" Padding="8" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <TextBlock Name="ErrorTextBlock" Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Page>
